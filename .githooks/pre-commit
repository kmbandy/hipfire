#!/usr/bin/env bash
# pre-commit hook: run the MQ4 quality gate when kernel/forward code changes.
#
# Install with:
#   git config core.hooksPath .githooks
#
# The gate is fully deterministic (greedy argmax). Any failure is a
# numerical correctness regression — do NOT bypass with --no-verify
# unless you have a plan to fix it in the same commit.

set -e

# List files staged for this commit.
CHANGED=$(git diff --cached --name-only --diff-filter=ACM)

# Regex for files that can plausibly affect forward-pass numerical output.
# Hot spots: GEMV kernels, FWHT rotation, RMSNorm, fused ops, quant formats,
# dispatch, forward loop, llama.rs helpers, qwen35.rs layer sequence.
HOTSPOT='\.hip$|gemv|forward|quant|rotate|dispatch|fwht|rmsnorm|fused|mq4|hfq|magnum|llama\.rs|qwen35\.rs'

if ! echo "$CHANGED" | grep -qE "$HOTSPOT"; then
    exit 0
fi

echo "=== MQ4 Quality Gate ==="
echo "Kernel or forward-pass code changed. Running --fast gate..."
echo

if ! ./scripts/quality-gate.sh --fast; then
    echo
    echo "========================================================================"
    echo "COMMIT BLOCKED: MQ4 output quality regression detected."
    echo "========================================================================"
    echo
    echo "The 4B MQ4 Federalist test diverged from the committed baseline."
    echo "This is a NUMERICAL CORRECTNESS BUG, not a model quality issue."
    echo
    echo "Next steps:"
    echo "  ./scripts/quality-gate.sh --verbose     # see the first divergent token"
    echo "  ./scripts/quality-gate.sh               # run all 9 tests"
    echo
    echo "If this output is INTENTIONAL and verified correct:"
    echo "  ./scripts/quality-gate.sh --update-baselines"
    echo "  git add tests/quality-baselines/"
    echo "  # then re-attempt the commit"
    echo
    echo "Do NOT bypass with --no-verify without a plan to fix in the same commit."
    exit 1
fi

echo
echo "=== Quality gate passed. Proceeding with commit. ==="
exit 0
